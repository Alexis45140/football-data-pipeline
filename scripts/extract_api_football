import requests
import pandas as pd

headers = {
    "x-rapidapi-key": "861fcd799fmshb22fb42bd6add54p1949d4jsn2071aea71eaa",
    "x-rapidapi-host": "free-api-live-football-data.p.rapidapi.com"
}

def extract_top_transfers(total_pages=3):
    url = "https://free-api-live-football-data.p.rapidapi.com/football-get-all-transfers"
    all_transfers = []

    for page in range(1, total_pages + 1):
        print(f"📡 Récupération de la page {page}...")
        response = requests.get(url, headers=headers, params={"page": str(page)})
        
        if response.status_code == 200:
            data = response.json()
            transfers = data.get('response', {}).get('transfers', [])
            
            for t in transfers:
                # GESTION DU MONTANT (FEE)
                # L'API renvoie souvent 'undisclosed'. On met 0 pour les calculs.
                fee_data = t.get('fee', {})
                fee_value = 0
                if isinstance(fee_data, dict):
                    # On essaie de récupérer une valeur numérique si elle existe, sinon 0
                    fee_value = fee_data.get('value', 0)

                # MAPPING AVEC LES NOUVELLES CLÉS DÉTECTÉES
                record = {
                    "joueur": t.get('name'),           # Changé de 'playerName' à 'name'
                    "club_depart": t.get('fromClub'),
                    "club_arrivee": t.get('toClub'),
                    "montant": fee_value,
                    "date_transfert": t.get('transferDate'),
                    # 'transferType' est maintenant un dictionnaire
                    "type_transfert": t.get('transferType', {}).get('text', 'N/A')
                }
                all_transfers.append(record)
        else:
            print(f"❌ Erreur API : {response.status_code}")

    df = pd.DataFrame(all_transfers)
    
    if not df.empty:
        # On affiche un aperçu pour vérifier que 'joueur' n'est plus vide
        print("\n✅ Aperçu des données (Les noms devraient être là !) :")
        print(df[['joueur', 'club_depart', 'club_arrivee']].head())
        
        df.to_csv("transferts_football.csv", index=False, encoding='utf-8-sig')
        print(f"\nFichier sauvegardé : {len(df)} lignes.")
    else:
        print("⚠️ Toujours aucune donnée...")

if __name__ == "__main__":
    extract_top_transfers(total_pages=3)